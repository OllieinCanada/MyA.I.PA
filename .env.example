DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myaipa?schema=public"
PORT=8787

ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-too
OWNER_SMS_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

REACT_APP_GOOGLE_MAPS_API_KEY=
# Local development can leave this blank and use the CRA proxy to PORT=8787.
# Production should point this at your backend API if using Stripe Checkout.
REACT_APP_API_BASE_URL=
REACT_APP_CHECKOUT_API_BASE_URL=
REACT_APP_MAKE_SIGNUP_WEBHOOK_URL=
REACT_APP_MAKE_SIGNUP_WEBHOOK_API_KEY=
REACT_APP_TURNSTILE_SITE_KEY=
OPENAI_API_KEY=YOUR_KEY
MAKE_SIGNUP_WEBHOOK_URL=
MAKE_SIGNUP_WEBHOOK_API_KEY=

# Stripe Checkout. Create a recurring Price in Stripe and paste its price_... ID here.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS=14
TRIAL_HALFWAY_REMINDER_DAYS=7
TRIAL_REMINDER_CHECK_INTERVAL_MS=3600000
TRIAL_REMINDER_DISABLE=false
STRIPE_ALLOW_PROMOTION_CODES=false
PUBLIC_APP_URL=http://localhost:3000
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

TURNSTILE_SECRET_KEY=
SIGNUP_REQUIRE_MANUAL_APPROVAL=false
SIGNUP_REQUIRE_VERIFICATION=false
SIGNUP_VERIFICATION_TTL_MS=86400000
SIGNUP_VERIFICATION_BASE_URL=http://localhost:8787
EMAIL_VERIFICATION_DEV_MODE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="My AI PA <hello@myaipa.com>"
SIGNUP_IP_MAX_REQUESTS=5
SIGNUP_IDENTITY_MAX_REQUESTS=2
STORE_CALL_TRANSCRIPTS=false
STORE_CALL_RECORDING_URLS=false
MAX_STORED_TRANSCRIPT_CHARS=4000
MAX_LEAD_SUMMARY_CHARS=1000
EXPOSE_CALL_TRANSCRIPTS_IN_ADMIN=false
EXPOSE_RECORDING_URLS_IN_ADMIN=false
CALL_TRANSCRIPT_RETENTION_DAYS=30
CALL_RECORDING_RETENTION_DAYS=30

# Vapi call-log sync. VAPI_BUSINESS_MAP maps Vapi assistant IDs, phone-number IDs,
# or phone numbers to local Business IDs.
VAPI_API_KEY=
VAPI_API_BASE_URL=https://api.vapi.ai
VAPI_CALL_LIMIT=100
VAPI_DEFAULT_BUSINESS_ID=1
VAPI_BUSINESS_MAP={"vapi-assistant-or-phone-number-id":1,"+12495033301":1}
VAPI_AUTO_SYNC_ENABLED=false
VAPI_AUTO_SYNC_INTERVAL_MS=900000

# Twilio per-call cost sync. Use the Twilio account connected to the Vapi phone numbers.
TWILIO_API_BASE_URL=https://api.twilio.com
MISSED_CALL_ALERT_ENABLED=false
DAILY_DIGEST_ENABLED=false

# Telegram screenshot delivery. Message the bot with /start before first use.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_URL=file:///C:/Users/Olive/OneDrive/Desktop/MyAIPA-Website/docs/index.html#/admin
