          <g class="msg">
            <rect x="175" y="290" width="550" height="520" rx="52" fill="url(#imsgGreen)"/>
            <path d="M235 730l-34 30 50-14" fill="url(#imsgGreen)"/>
            <text x="235" y="385" font-family="Helvetica, Arial, sans-serif" font-size="34" font-weight="700" fill="#f2fff6">New lead captured!</text>
            <text x="235" y="445" font-family="Helvetica, Arial, sans-serif" font-size="28" font-weight="600" fill="#f2fff6">Name: Jamie L.</text>
            <text x="235" y="490" font-family="Helvetica, Arial, sans-serif" font-size="28" font-weight="600" fill="#f2fff6">Phone: (555) 123-4567</text>
            <text x="235" y="535" font-family="Helvetica, Arial, sans-serif" font-size="28" font-weight="600" fill="#f2fff6">Service request: Hot tub installation</text>
            <text x="235" y="580" font-family="Helvetica, Arial, sans-serif" font-size="28" font-weight="600" fill="#f2fff6">Date of job: Feb 13, 2026</text>
            <text x="235" y="625" font-family="Helvetica, Arial, sans-serif" font-size="28" font-weight="600" fill="#f2fff6">Location: 1234 Yonge Street</text>
            <text x="235" y="670" font-family="Helvetica, Arial, sans-serif" font-size="28" font-weight="600" fill="#f2fff6">Call back time: Today 3:30 PM</text>
          </g>
        </svg>
      `),
      visualTitle: "Lead capture",
      visualSub: "Gets the info you need to close",
    },
    {
      phrase: "books appointments.",
      bullets: ["Auto-schedules callbacks", "Creates calendar reminders", "Sends client details"],
      image: svgData(`
        <svg xmlns="http://www.w3.org/2000/svg" width="900" height="1200" viewBox="0 0 900 1200">
          <defs>
            <linearGradient id="g4" x1="0" x2="1" y1="0" y2="1">
              <stop offset="0%" stop-color="#2d3047"/>
              <stop offset="100%" stop-color="#3a86ff"/>
            </linearGradient>
          </defs>
          <style>
            .check-anim { opacity: 0; }
            .menu-card { opacity: 0; }
            .menu-check { opacity: 0; }
          </style>
          <rect width="900" height="1200" fill="url(#g4)"/>
          <rect x="160" y="240" width="580" height="700" rx="40" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.25)" stroke-width="2"/>
          <rect x="160" y="240" width="580" height="130" rx="40" fill="rgba(255,255,255,0.18)"/>
          <circle cx="270" cy="305" r="18" fill="rgba(0,0,0,0.35)"/>
          <circle cx="630" cy="305" r="18" fill="rgba(0,0,0,0.35)"/>
          <text x="450" y="325" font-family="Arial, sans-serif" font-size="40" font-weight="700" text-anchor="middle" fill="rgba(255,255,255,0.9)">Calendar</text>
          <rect x="210" y="420" width="480" height="420" rx="20" fill="rgba(255,255,255,0.12)"/>
          <g fill="rgba(255,255,255,0.22)">
            <rect x="240" y="460" width="90" height="80" rx="12"/>
            <rect x="350" y="460" width="90" height="80" rx="12"/>
            <rect x="460" y="460" width="90" height="80" rx="12"/>
            <rect x="570" y="460" width="90" height="80" rx="12"/>
            <rect x="240" y="560" width="90" height="80" rx="12"/>
            <rect x="350" y="560" width="90" height="80" rx="12"/>
            <rect x="460" y="560" width="90" height="80" rx="12"/>
            <rect x="570" y="560" width="90" height="80" rx="12"/>
            <rect x="240" y="660" width="90" height="80" rx="12"/>
            <rect x="350" y="660" width="90" height="80" rx="12"/>
            <rect x="460" y="660" width="90" height="80" rx="12"/>
