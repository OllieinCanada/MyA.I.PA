            <div className="mx-auto w-full max-w-md rounded-3xl bg-white p-10 shadow-[0_25px_60px_-40px_rgba(0,0,0,0.35)] ring-1 ring-slate-200">
              <div className="text-center">
                <div className="text-sm font-bold text-slate-500">Starting at</div>
                <div className="mt-3 text-6xl font-black">
                  $49<span className="text-lg font-extrabold text-slate-500">/month</span>
                </div>
                <div className="mt-2 text-sm font-semibold text-slate-500">Billed monthly • Cancel anytime</div>

                <div className="mt-8 rounded-2xl bg-emerald-50 px-5 py-4 text-sm font-extrabold text-emerald-800 ring-1 ring-emerald-100">
                  All plans include unlimited minutes!
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* Big CTA + Footer */}
      <section className="mt-10 bg-emerald-800">
        <div data-reveal className="reveal mx-auto max-w-6xl px-6 py-20 text-center text-white">
          <div className="mx-auto inline-flex items-center rounded-full bg-white/10 px-4 py-2 text-sm font-extrabold">
