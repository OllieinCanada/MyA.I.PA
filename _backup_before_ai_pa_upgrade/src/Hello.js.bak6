          </div>

          <div className="mt-5 text-sm font-semibold text-white/70">No credit card required • 14-day free trial • Cancel anytime</div>
        </div>

        <footer id="about" className="border-t border-white/10">
          <div className="mx-auto grid max-w-6xl gap-10 px-6 py-12 md:grid-cols-4">
            <div className="text-white">
              <div className="flex items-center gap-3">
                <div className="grid h-10 w-10 place-items-center rounded-2xl bg-white/10 text-white">
                  <IconPhone className="h-5 w-5" />
                </div>
                <span className="text-lg font-extrabold">My AI PA</span>
              </div>
              <p className="mt-4 text-sm font-semibold text-white/75">
                Your AI-powered phone assistant that answers calls 24/7, captures leads, and ensures you never miss a
                business opportunity.
              </p>
              <div className="mt-5 space-y-2 text-sm font-semibold text-white/75">
                <div>hello@myaipa.com</div>
                <div>1-800-MY-AI-PA</div>
              </div>
            </div>

            {[
              { title: "Product", links: ["Features", "How It Works", "Pricing", "Integrations"] },
              { title: "Company", links: ["About Us", "Blog", "Careers", "Contact"] },
              { title: "Legal", links: ["Privacy Policy", "Terms of Service", "Cookie Policy"] },
            ].map((col) => (
              <div key={col.title} className="text-white">
                <div className="text-sm font-extrabold">{col.title}</div>
