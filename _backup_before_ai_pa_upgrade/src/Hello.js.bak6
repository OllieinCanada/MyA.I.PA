      `),
      visualTitle: "Scheduling",
      visualSub: "Turns calls into booked work",
    },
  ];

  const [activeHeroIndex, setActiveHeroIndex] = useState(0);
  useEffect(() => {
    const elements = Array.from(document.querySelectorAll("[data-reveal]"));
    if (!elements.length) return;

    const prefersReduced = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReduced) {
      elements.forEach((el) => el.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: "0px 0px -10% 0px" }
    );

    elements.forEach((el) => observer.observe(el));
    return () => observer.disconnect();
  }, []);

  return (
    <div className="min-h-screen bg-[#fbfaf6] text-slate-900">
      <style>{`
        @keyframes letterRiseIn {
          0% { transform: translateY(16px); opacity: 0; filter: blur(0.2px); }
          70% { opacity: 1; }
          100% { transform: translateY(0px); opacity: 1; filter: blur(0px); }
        }
        @keyframes letterFallOut {
          0% { transform: translateY(0px); opacity: 1; }
          100% { transform: translateY(16px); opacity: 0; }
        }
        @keyframes heroPopIn {
          0% { transform: translateY(30px) scale(0.95); opacity: 0; filter: blur(2px); }
          70% { opacity: 1; }
          100% { transform: translateY(0px) scale(1); opacity: 1; filter: blur(0px); }
        }
        @keyframes slideWipe {
          0% { transform: translateX(-130%); opacity: 0; }
          20% { opacity: 0.8; }
          100% { transform: translateX(130%); opacity: 0; }
        }
        .fallIn { animation: letterRiseIn 520ms cubic-bezier(.2,.9,.2,1) both; }
        .fallOut { animation: letterFallOut 520ms cubic-bezier(.2,.9,.2,1) both; }
        .heroPop { animation: heroPopIn 650ms cubic-bezier(.2,.9,.2,1) both; will-change: transform, opacity, filter; }
        .slideWipe {
          background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.35) 45%, rgba(255,255,255,0.05) 60%, transparent 75%);
          animation: slideWipe 900ms ease-out both;
          border-radius: 56px;
          mix-blend-mode: screen;
        }
        .reveal {
          opacity: 0;
          transform: translateY(28px) scale(0.985);
          transition: transform 700ms cubic-bezier(.2,.9,.2,1), opacity 700ms ease;
          will-change: transform, opacity;
        }
        .reveal.is-visible {
          opacity: 1;
          transform: translateY(0px) scale(1);
        }
        .reveal-delay-1 { transition-delay: 120ms; }
        .reveal-delay-2 { transition-delay: 240ms; }
      `}</style>

      {/* Top Nav */}
      <header className="sticky top-0 z-50 border-b border-white/20 bg-white/75 backdrop-blur">
        <div className="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
          <div className="flex items-center gap-3">
            <div className="grid h-10 w-10 place-items-center rounded-2xl bg-emerald-700 text-white shadow-[0_10px_24px_-16px_rgba(0,0,0,0.5)]">
              <IconPhone className="h-5 w-5" />
            </div>
            <div className="flex flex-col">
              <span className="text-lg font-extrabold tracking-tight text-slate-900">My AI PA</span>
              <span className="text-[11px] font-bold uppercase tracking-[0.22em] text-emerald-700/80">AI Phone Agent</span>
            </div>
          </div>

          <nav className="hidden items-center gap-8 text-sm font-semibold text-slate-600 md:flex">
            {[
              { label: "Features", href: "#features" },
              { label: "How It Works", href: "#how" },
              { label: "Pricing", href: "#pricing" },
              { label: "About", href: "#about" },
            ].map((x) => (
              <a
                key={x.label}
                href={x.href}
                className="relative hover:text-slate-900 after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-0 after:bg-emerald-600 after:transition-all after:duration-300 hover:after:w-full"
              >
                {x.label}
              </a>
            ))}
          </nav>

          <div className="flex items-center gap-3">
            <a href="#login" className="hidden text-sm font-bold text-slate-700 hover:text-slate-900 md:block">
              Login
            </a>
            <button className="hidden rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-extrabold text-slate-700 hover:border-slate-300 hover:bg-slate-50 md:inline-flex">
              Book a Demo
            </button>
            <PrimaryButton className="px-6 py-3 text-sm">Get Started Free</PrimaryButton>
          </div>
        </div>
      </header>

      {/* HERO */}
      <section className="relative z-0 overflow-hidden">
        <div className="absolute inset-0">
          <div className="absolute inset-0 bg-[#0b0b12]" />
          <div className="absolute inset-0 bg-[radial-gradient(1200px_600px_at_30%_30%,rgba(255,96,96,0.28),transparent_58%)]" />
          <div className="absolute inset-0 bg-[radial-gradient(900px_500px_at_75%_60%,rgba(255,180,60,0.14),transparent_60%)]" />
          <div className="absolute inset-0 bg-gradient-to-b from-white/0 via-white/0 to-[#fbfaf6]" />
        </div>

        <div className="relative mx-auto max-w-6xl px-6 pt-12 pb-16">
          <div className="grid gap-12 lg:grid-cols-2 lg:items-center">
            <div className="relative text-left">
              <div className="pointer-events-none absolute -inset-x-4 -inset-y-3 rounded-3xl bg-black/40 backdrop-blur-[1px]" />
              <div className="relative z-10 max-w-[560px]">
                <TextSlideshow slides={heroSlides} className="max-w-xl" onIndexChange={setActiveHeroIndex} />

                <p className="mt-6 max-w-xl text-lg sm:text-xl font-semibold leading-8 text-white/90 drop-shadow-[0_2px_10px_rgba(0,0,0,0.45)]">
                  Answer every call instantly, capture leads automatically, and follow up fast—without lifting a finger.
                </p>

                <div className="mt-8 flex flex-wrap items-center gap-4">
                  <PrimaryButton className="px-7 py-3.5 text-base">Get Started, It&apos;s Free!</PrimaryButton>
                  <GhostButtonDark className="border-white/10 bg-transparent text-white/70 hover:text-white hover:bg-white/5">
                    See How It Works
                  </GhostButtonDark>
                </div>

                <div className="mt-10 flex flex-wrap items-center gap-3 text-[11px] font-extrabold uppercase tracking-[0.18em] text-white/75">
                  {["Plumbing", "Dental", "Legal", "HVAC", "Home Services"].map((label) => (
                    <span key={label} className="rounded-full border border-white/20 px-3 py-1">
                      {label}
                    </span>
                  ))}
                </div>
              </div>
            </div>
            <div className="pb-4">
              <SlideVisual slides={heroSlides} activeIndex={activeHeroIndex} />
            </div>
          </div>
        </div>
      </section>

      {/* PROBLEM */}
      <section className="mx-auto max-w-6xl px-6 py-16">
        <div className="grid gap-10 md:grid-cols-2 lg:grid-cols-[1fr_1.15fr] md:items-start">
          <div data-reveal className="reveal">
            <div className="text-3xl font-black uppercase tracking-wide text-emerald-950">THE PROBLEM</div>
            <h2 className="mt-5 text-5xl font-black leading-tight text-emerald-950">Missed Calls Are Lost Revenue</h2>
            <p className="mt-4 text-lg font-semibold text-slate-700">
              Customers want immediate help—and won&apos;t wait for voicemail callbacks.
            </p>
            <p className="mt-4 text-lg font-medium text-slate-600">
              Every missed call can turn into a lost job. Use the calculator to estimate the revenue you&apos;re leaving on the
              table each month.
            </p>
            <RoiCalculatorResults
              estimatedJobsLostPerMonth={estimatedJobsLostPerMonth}
              displayRevenuePerMonth={displayMonthlyLoss}
              pulse={pulseRecover}
              className="mt-10 max-w-sm lg:sticky lg:top-24"
            />
          </div>

          <div data-reveal className="reveal reveal-delay-1">
            <RoiCalculator
              missedCallsPerWeek={missedCallsPerWeek}
              setMissedCallsPerWeek={setMissedCallsPerWeek}
              avgRevenuePerJob={avgRevenuePerJob}
              setAvgRevenuePerJob={setAvgRevenuePerJob}
              bookingRate={bookingRate}
              setBookingRate={setBookingRate}
            />
          </div>
        </div>
      </section>

      {/* SOLUTION */}
      <section id="features" className="mx-auto max-w-6xl px-6 pb-16">
        <div className="grid gap-10 md:grid-cols-2 md:items-center">
          <div data-reveal className="reveal">
            <SectionTag text="The Solution" icon={<span className="text-emerald-600">✦</span>} />
            <h2 className="mt-5 text-6xl font-black leading-[1.02] text-emerald-950">Let&apos;s Fix It With AI</h2>
            <p className="mt-5 text-lg font-medium text-slate-600">
              My AI PA answers every call, takes messages, books appointments, and makes sure missed calls turn into
              revenue—24 hours a day, 7 days a week.
            </p>
            <div className="mt-5 rounded-[24px] bg-slate-900 p-6 text-white shadow-[0_24px_60px_-40px_rgba(0,0,0,0.6)] ring-1 ring-black/10">
              <div className="flex items-center justify-between gap-3">
                <div className="text-sm font-extrabold text-white/85">Recovered revenue (projected)</div>
                <span className="rounded-full bg-white/10 px-3 py-1 text-xs font-extrabold text-white/80 ring-1 ring-white/10">
                  estimate
                </span>
              </div>
              <div className="mt-1 text-xs font-semibold text-white/60">Based on your missed-call inputs</div>

              <div className="mt-4 rounded-2xl bg-white/6 p-4 ring-1 ring-white/10">
                <svg
                  viewBox={`0 0 ${recoveredChart.w} ${recoveredChart.h}`}
                  className="h-32 w-full"
                  aria-label="Recovered revenue growth chart"
                >
                  <defs>
                    <linearGradient id="recoveredArea" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="#34d399" stop-opacity="0.4" />
                      <stop offset="100%" stop-color="#34d399" stop-opacity="0" />
                    </linearGradient>
                    <linearGradient id="recoveredLine" x1="0" x2="1" y1="0" y2="0">
                      <stop offset="0%" stop-color="#34d399" />
                      <stop offset="100%" stop-color="#22c55e" />
                    </linearGradient>
                  </defs>
                  <path d={`M ${recoveredChart.area}`} fill="url(#recoveredArea)" />
                  <polyline
                    points={recoveredChart.points}
                    fill="none"
                    stroke="url(#recoveredLine)"
                    strokeWidth="4"
                    strokeLinecap="round"
                    strokeLinejoin="round"
                  />
                </svg>
                <div className="mt-2 flex items-center justify-between text-xs font-semibold text-white/60">
                  <span>Month 1</span>
                  <span>Month 6</span>
                </div>
              </div>

              <div className="mt-5 grid grid-cols-3 gap-3 text-xs font-semibold text-white/70">
                <div>
                  <div className="text-white/50">Monthly</div>
                  <div className="mt-1 text-base font-extrabold text-white tabular-nums">
                    {moneyUSD(displayMonthlyLoss)}
                  </div>
                </div>
                <div>
                  <div className="text-white/50">Weekly</div>
                  <div className="mt-1 text-base font-extrabold text-white tabular-nums">
                    {moneyUSD(displayWeeklyLoss)}
                  </div>
                </div>
                <div>
                  <div className="text-white/50">Yearly</div>
                  <div className="mt-1 text-base font-extrabold text-white tabular-nums">
                    {moneyUSD(displayYearlyLoss)}
                  </div>
                </div>
              </div>

              <div className="mt-4 text-sm font-semibold leading-6 text-white/70">
                Shows projected growth as missed calls are recovered by My AI PA.
              </div>
            </div>

            <ul className="mt-8 space-y-4 text-base font-semibold text-slate-700">
              {[
                "Answers every call on the first ring",
