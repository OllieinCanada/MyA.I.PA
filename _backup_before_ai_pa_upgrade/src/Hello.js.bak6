          <g>
            <animateTransform attributeName="transform" type="translate" values="0 0;0 0;0 2;0 0" keyTimes="0;0.35;0.5;1" dur="4s" repeatCount="indefinite"/>
            <animateTransform attributeName="transform" type="scale" additive="sum" values="1 1;1 1;0.985 0.985;1 1" keyTimes="0;0.35;0.5;1" dur="4s" repeatCount="indefinite"/>
            <rect x="350" y="560" width="90" height="80" rx="12" fill="rgba(255,255,255,0.22)">
              <animate attributeName="fill" values="rgba(255,255,255,0.22);rgba(255,255,255,0.22);#ffd166;#ffd166" keyTimes="0;0.4;0.45;1" dur="4s" repeatCount="indefinite"/>
            </rect>
            <path class="check-anim" d="M372 600l14 14 30-36" fill="none" stroke="#2d2d2d" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
              <animate attributeName="opacity" values="0;0;1" keyTimes="0;0.4;1" dur="4s" repeatCount="indefinite"/>
              <animate attributeName="stroke-dasharray" values="0 80;80 0;80 0" keyTimes="0;0.4;1" dur="4s" repeatCount="indefinite"/>
