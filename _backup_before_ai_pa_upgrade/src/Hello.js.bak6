            <circle class="badge" cx="540" cy="420" r="28" fill="#ff3b30"/>
            <text class="badge" x="540" y="430" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="800" fill="#ffffff">1</text>
            <text x="450" y="628" text-anchor="middle" font-family="Arial, sans-serif" font-size="22" font-weight="700" fill="rgba(255,255,255,0.9)">
