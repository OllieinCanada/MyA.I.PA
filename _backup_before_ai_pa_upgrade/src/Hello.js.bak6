/* ----------------- HERO: slideshow text (letters) ----------------- */
function TextSlideshow({ slides, autoMs = 8000, className = "", onIndexChange }) {
  const [i, setI] = useState(0);
  const [prevPhrase, setPrevPhrase] = useState(null);
  const timerRef = useRef(null);

  const count = slides.length;
  const animMs = 520;

  const next = () => setI((x) => (x + 1) % count);
  const go = (idx) => {
    clearTimeout(timerRef.current);
    setI(idx);
  };

  useEffect(() => {
    onIndexChange?.(i);
  }, [i, onIndexChange]);

  const activeDuration = slides[i]?.duration ?? autoMs;

  useEffect(() => {
    if (count <= 1) return;
    clearTimeout(timerRef.current);
    timerRef.current = setTimeout(next, activeDuration);
    return () => clearTimeout(timerRef.current);
  }, [count, activeDuration, i]);

  useEffect(() => {
    if (count <= 1) return;
    const prevIdx = (i - 1 + count) % count;
    setPrevPhrase(slides[prevIdx]?.phrase ?? null);
  }, [i]);

  useEffect(() => {
    if (!prevPhrase) return;
    const t = setTimeout(() => setPrevPhrase(null), animMs);
    return () => clearTimeout(t);
  }, [prevPhrase, animMs]);

  const active = slides[i];

  const renderLetters = (text, mode) => (
    <span className="inline-block whitespace-normal">
      {Array.from(text).map((ch, idx) => {
        if (ch === " ") {
          return <span key={mode + "-" + idx + "-space"} className="inline-block w-[0.35em]" />;
        }
        return (
          <span
            key={mode + "-" + idx + "-" + ch}
            className={"inline-block will-change-transform " + (mode === "in" ? "fallIn" : "fallOut")}
            style={{ animationDelay: `${idx * 14}ms` }}
          >
            {ch}
          </span>
        );
      })}
    </span>
  );

  return (
    <div className={"relative " + className}>
      <div key={"hero-" + i} className="heroPop">
        <h1 className="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.02] tracking-tight text-white drop-shadow-[0_6px_20px_rgba(0,0,0,0.55)]">
          Your AI agent that{" "}
          <span className="relative inline-block align-baseline">
            <span className="absolute -inset-x-2 inset-y-1 -skew-x-6 rounded-xl bg-amber-400/20 blur-[0.2px]" />
            <span className="relative inline-block px-2">
              {prevPhrase && <span className="absolute left-0 top-0">{renderLetters(prevPhrase, "out")}</span>}
              <span className="inline-block">{renderLetters(active.phrase, "in")}</span>
            </span>
          </span>
        </h1>
        <ul className="mt-7 max-w-xl space-y-3 text-base sm:text-lg font-semibold leading-7 text-white/95 drop-shadow-[0_2px_10px_rgba(0,0,0,0.45)]">
          {active.bullets?.map((b) => (
            <li key={b} className="flex items-start gap-3">
              <span className="mt-2 h-1.5 w-1.5 rounded-full bg-amber-300/90 shadow-[0_0_10px_rgba(251,191,36,0.6)]" />
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <div className="mt-9 flex items-center gap-2">
        {slides.map((_, idx) => (
          <button
            key={idx}
            type="button"
            onClick={() => go(idx)}
            className={
              "h-2.5 w-2.5 rounded-full ring-1 ring-white/15 transition " +
              (idx === i ? "bg-amber-400" : "bg-white/25")
            }
            aria-label={"Go to slide " + (idx + 1)}
          />
        ))}
      </div>
    </div>
  );
}

/* ----------------- HERO: visual stack synced to slides ----------------- */
function SlideVisual({ slides, activeIndex }) {
  return (
    <div className="relative mx-auto w-full max-w-[460px]">
      <div key={"wipe-" + activeIndex} className="slideWipe pointer-events-none absolute -inset-6 z-30" />
      <div className="pointer-events-none absolute -inset-8 rounded-[48px] bg-[radial-gradient(420px_260px_at_60%_35%,rgba(255,180,60,0.15),transparent_65%)] blur-xl" />

      <div className="relative h-[520px]">
        {slides.map((s, idx) => {
          const isActive = idx === activeIndex;
          const depth = idx - activeIndex;

          const z = isActive ? 40 : 20 - Math.abs(depth);
          const translate = isActive
            ? "translate3d(0,0,0)"
            : `translate3d(${10 + Math.abs(depth) * 10}px, ${10 + Math.abs(depth) * 12}px, 0)`;
          const scale = isActive ? 1 : 0.98 - Math.min(0.03, Math.abs(depth) * 0.01);
          const opacity = isActive ? 1 : 0.15;
          const blur = isActive ? "blur(0px)" : "blur(1.5px)";

          return (
            <div
              key={s.image + idx}
              className="absolute inset-0 transition-all duration-500 ease-out"
              style={{
                zIndex: z,
                transform: `${translate} scale(${scale})`,
                opacity,
                filter: blur,
              }}
            >
              <div className="relative h-full overflow-hidden rounded-[36px] shadow-[0_30px_70px_-45px_rgba(0,0,0,0.8)] ring-1 ring-white/10">
                {isActive ? (
                  <img key={"active-" + activeIndex} src={s.image} alt="" className="h-full w-full object-cover" />
                ) : (
                  <img key={"inactive-" + idx} src={s.image} alt="" className="h-full w-full object-cover" />
                )}
                <div className="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-black/0" />
                {isActive &&
                  s.avatars?.map((avatar, avatarIndex) => (
                    <div
                      key={avatar.src + avatarIndex}
                      className="absolute z-20 -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-full shadow-[0_12px_26px_rgba(0,0,0,0.5)]"
                      style={{
                        left: `${avatar.x}%`,
                        top: `${avatar.y}%`,
                        width: `${avatar.size ?? 28}%`,
                        height: `${avatar.size ?? 28}%`,
                      }}
                    >
                      <img src={avatar.src} alt="" className="h-full w-full object-cover" />
                    </div>
                  ))}

                
              </div>
            </div>
          );
        })}
      </div>

      <div className="mt-4 flex items-center justify-end text-xs font-extrabold text-white/70">
        <span className="text-white/60">
          {activeIndex + 1}/{slides.length}
        </span>
      </div>
    </div>
  );
}

/* ----------------- page ----------------- */
export default function App() {
  const [missedCallsPerWeek, setMissedCallsPerWeek] = useState("6");
  const [avgRevenuePerJob, setAvgRevenuePerJob] = useState("2550");
  const [bookingRate, setBookingRate] = useState("35");

  const missedCallsNum = clamp(Number(missedCallsPerWeek) || 0, 0, 50);
  const avgRevenueNum = clamp(Number(avgRevenuePerJob) || 0, 0, 5000);
  const bookingRateNum = clamp(Number(bookingRate) || 0, 0, 100);

  const estimatedJobsLostPerMonth = missedCallsNum * 4.33 * (bookingRateNum / 100);
  const estimatedRevenueLostPerMonth = estimatedJobsLostPerMonth * avgRevenueNum;

  const [displayMonthlyLoss, setDisplayMonthlyLoss] = useState(0);
  const [pulseRecover, setPulseRecover] = useState(false);
  useEffect(() => {
    let start = displayMonthlyLoss;
    let end = estimatedRevenueLostPerMonth;
    const duration = 450;
    let startTime = null;

    const animate = (t) => {
      if (!startTime) startTime = t;
      const p = Math.min((t - startTime) / duration, 1);
      const v = start + (end - start) * p;
      setDisplayMonthlyLoss(v);
      if (p < 1) requestAnimationFrame(animate);
    };

    requestAnimationFrame(animate);
  }, [estimatedRevenueLostPerMonth]);

  useEffect(() => {
    setPulseRecover(true);
    const t = setTimeout(() => setPulseRecover(false), 420);
    return () => clearTimeout(t);
  }, [estimatedRevenueLostPerMonth]);

  const displayWeeklyLoss = displayMonthlyLoss / 4.33;
  const displayYearlyLoss = displayMonthlyLoss * 12;
  const recoveredSeries = useMemo(() => {
    const base = Math.max(0, displayMonthlyLoss || estimatedRevenueLostPerMonth);
    const factors = [0.6, 0.75, 0.9, 1, 1.1, 1.25];
    return factors.map((f) => base * f);
  }, [displayMonthlyLoss, estimatedRevenueLostPerMonth]);

  const recoveredChart = useMemo(() => {
    const w = 320;
    const h = 120;
    const pad = 10;
    const min = Math.min(...recoveredSeries);
    const max = Math.max(...recoveredSeries);
    const range = max - min || 1;
    const points = recoveredSeries
      .map((v, i) => {
        const x = pad + (i / (recoveredSeries.length - 1)) * (w - pad * 2);
        const y = h - pad - ((v - min) / range) * (h - pad * 2);
        return `${x},${y}`;
      })
      .join(" ");
    const area = `${pad},${h - pad} ${points} ${w - pad},${h - pad}`;
    return { w, h, points, area };
  }, [recoveredSeries]);
  const heroSlides = [
    {
      phrase: "handles missed calls.",
      bullets: [
        "Always answers the phone when you're unavailable.",
        "A professional voice with accurate company information.",
        "Collects details for new jobs.",
