            <linearGradient id="bubble" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#f6f9ff" stop-opacity="0.95"/>
              <stop offset="100%" stop-color="#e8f0ff" stop-opacity="0.9"/>
            </linearGradient>
            <clipPath id="imsgClip" clipPathUnits="userSpaceOnUse">
              <rect x="350" y="400" width="200" height="200" rx="44"/>
            </clipPath>
          </defs>
          <style>
            .notif, .msg, .badge { transform-box: fill-box; transform-origin: center; }
            .notif { animation: notifHold 8s ease-in-out infinite; }
            .badge { animation: badgePop 8s ease-in-out infinite; }
            .msg { animation: msgReveal 8s ease-in-out infinite; }
            @keyframes notifHold {
              0% { opacity: 1; transform: scale(1); }
              25% { opacity: 1; transform: scale(1.02); }
              38% { opacity: 0; transform: scale(0.9); }
              100% { opacity: 0; transform: scale(0.9); }
            }
            @keyframes badgePop {
              0% { opacity: 0; transform: scale(0.3); }
              8% { opacity: 1; transform: scale(1.05); }
              14% { opacity: 1; transform: scale(1); }
              38% { opacity: 1; }
              50% { opacity: 0; }
              100% { opacity: 0; }
            }
            @keyframes msgReveal {
              0% { opacity: 0; transform: scale(0.2); }
              30% { opacity: 0; transform: scale(0.2); }
              48% { opacity: 1; transform: scale(1.03); }
              100% { opacity: 1; transform: scale(1); }
            }
          </style>

          <rect width="900" height="1200" fill="url(#g3)"/>
          <rect x="170" y="240" width="560" height="700" rx="42" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.25)" stroke-width="2"/>

          <g class="notif">
