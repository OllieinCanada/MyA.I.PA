/* ----------------- tiny helpers ----------------- */
const clamp = (n, min, max) => Math.min(max, Math.max(min, n));
const moneyUSD = (n) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(Math.round(n || 0));
const svgData = (svg) => `data:image/svg+xml;utf8,${encodeURIComponent(svg)}`;

