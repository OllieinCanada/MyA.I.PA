          <g class="menu-card">
            <rect x="420" y="300" width="440" height="320" rx="28" fill="#eef3ff" stroke="rgba(255,255,255,0.8)" stroke-width="1.5"/>
            <rect x="420" y="300" width="440" height="72" rx="28" fill="#e1e8ff"/>
            <text x="458" y="345" font-family="Arial, sans-serif" font-size="32" font-weight="700" fill="#2b2f3a">New job date</text>
            <text x="458" y="435" font-family="Arial, sans-serif" font-size="26" font-weight="600" fill="#2b2f3a">Date: Fri 3:30 PM</text>
            <text x="458" y="485" font-family="Arial, sans-serif" font-size="26" font-weight="600" fill="#2b2f3a">Notify: 30 min before</text>
            <text x="458" y="535" font-family="Arial, sans-serif" font-size="26" font-weight="600" fill="#2b2f3a">Client: Jamie L.</text>
