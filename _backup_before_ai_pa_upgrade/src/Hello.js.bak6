                  {col.links.map((l) => (
            <li key={l}>
                      <a href="#/" className="hover:text-white">
                        {l}
                      </a>
            </li>
                  ))}
        </ul>
              </div>
            ))}
          </div>

          <div className="border-t border-white/10 py-6 text-center text-xs font-semibold text-white/60">
            © {new Date().getFullYear()} My AI PA. All rights reserved.
